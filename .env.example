# Database (Neon PostgreSQL — required by Prisma)
# Get from: Neon console → your project → Connection string (pooled)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Neon Auth (for Neon-native auth integration)
# Get from: Neon console → your project → Neon Auth
NEON_AUTH_URL="https://ep-xxxx.neonauth.region.aws.neon.tech/neondb/auth"

# Neon Data API (PostgREST HTTP endpoint for runtime queries)
# Typically: https://<endpoint-host>/<database>
NEON_DATA_API_URL="https://ep-xxxx-pooler.region.aws.neon.tech/neondb"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# OAuth providers (optional — at least one required)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Anthropic (for agent execution)
ANTHROPIC_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
