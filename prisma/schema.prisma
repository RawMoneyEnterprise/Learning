// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum IssueStatus {
  backlog
  todo
  in_progress
  in_review
  done
  blocked
  cancelled
}

enum Priority {
  critical
  high
  medium
  low
}

enum AgentStatus {
  idle
  running
  paused
  error
}

enum RunStatus {
  running
  completed
  failed
  cancelled
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum ProjectStatus {
  active
  completed
  archived
}

enum GoalStatus {
  active
  completed
  cancelled
}

enum AgentScope {
  global      // CxMO-built, available to all clients
  marketplace // Third-party, opt-in per client
  private     // Client-owned, isolated to that client
}

// ─────────────────────────────────────────────
// Auth (NextAuth.js required models)
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// Core Models
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?   // set for credentials (email/password) accounts
  companyId     String?
  company       Company?  @relation(fields: [companyId], references: [id])
  createdIssues Issue[]   @relation("IssueCreatedBy")
  assignedIssues Issue[]  @relation("IssueAssignedToUser")
  comments      Comment[]
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Company {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique // used as issue identifier prefix e.g. "CXM"
  users     User[]
  agents    Agent[]
  projects  Project[]
  goals     Goal[]
  issues    Issue[]
  labels    Label[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id          String        @id @default(cuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id])
  name        String
  description String?
  status      ProjectStatus @default(active)
  targetDate  DateTime?
  issues      Issue[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([companyId])
}

model Goal {
  id          String     @id @default(cuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  title       String
  description String?
  status      GoalStatus @default(active)
  level       String     @default("company") // company | team | personal
  parentId    String?
  parent      Goal?      @relation("GoalHierarchy", fields: [parentId], references: [id])
  children    Goal[]     @relation("GoalHierarchy")
  issues      Issue[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([companyId])
}

model Issue {
  id              String      @id @default(cuid())
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id])
  projectId       String?
  project         Project?    @relation(fields: [projectId], references: [id])
  goalId          String?
  goal            Goal?       @relation(fields: [goalId], references: [id])
  parentId        String?
  parent          Issue?      @relation("IssueHierarchy", fields: [parentId], references: [id])
  children        Issue[]     @relation("IssueHierarchy")
  title           String
  description     String?     @db.Text
  status          IssueStatus @default(backlog)
  priority        Priority    @default(medium)
  assigneeAgentId String?
  assigneeAgent   Agent?      @relation(fields: [assigneeAgentId], references: [id])
  assigneeUserId  String?
  assigneeUser    User?       @relation("IssueAssignedToUser", fields: [assigneeUserId], references: [id])
  createdByUserId String?
  createdBy       User?       @relation("IssueCreatedBy", fields: [createdByUserId], references: [id])
  comments        Comment[]
  runs            Run[]
  approvals       Approval[]
  labels          Label[]
  issueNumber     Int         // auto-increment per company (set in application layer)
  identifier      String      @unique // e.g. "CXM-1"
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([companyId, status])
  @@index([assigneeAgentId])
  @@index([projectId])
}

model Agent {
  id               String      @id @default(cuid())
  companyId        String
  company          Company     @relation(fields: [companyId], references: [id])
  name             String
  role             String
  title            String?
  description      String?     @db.Text
  capabilities     String?     @db.Text
  status           AgentStatus @default(idle)
  scope            AgentScope  @default(global)
  clientNamespace  String?     // "clients/{companyId}" — set only when scope = private
  apiKeyEncrypted  String?     // encrypted Claude API key
  budgetCents      Int         @default(0)
  spentCents       Int         @default(0)
  reportsToId      String?
  reportsTo        Agent?      @relation("AgentHierarchy", fields: [reportsToId], references: [id])
  reports          Agent[]     @relation("AgentHierarchy")
  assignedIssues   Issue[]
  runs             Run[]
  activations      ClientAgentActivation[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([companyId])
  @@index([scope])
  @@index([clientNamespace])
}

model ClientAgentActivation {
  id          String   @id @default(cuid())
  clientId    String   // companyId of the activating client
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  activatedAt DateTime @default(now())

  @@unique([clientId, agentId])
  @@index([clientId])
  @@index([agentId])
}

model Run {
  id         String    @id @default(cuid())
  issueId    String
  issue      Issue     @relation(fields: [issueId], references: [id])
  agentId    String
  agent      Agent     @relation(fields: [agentId], references: [id])
  status     RunStatus @default(running)
  output     String?   @db.Text
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([issueId])
  @@index([agentId])
}

model Comment {
  id            String   @id @default(cuid())
  issueId       String
  issue         Issue    @relation(fields: [issueId], references: [id])
  authorUserId  String?
  authorUser    User?    @relation(fields: [authorUserId], references: [id])
  authorAgentId String?
  body          String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([issueId])
}

model Approval {
  id            String         @id @default(cuid())
  issueId       String
  issue         Issue          @relation(fields: [issueId], references: [id])
  title         String
  body          String?        @db.Text
  status        ApprovalStatus @default(pending)
  requestedById String?
  resolvedById  String?
  resolvedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([issueId])
}

model Label {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  color     String
  issues    Issue[]
  createdAt DateTime @default(now())

  @@unique([companyId, name])
}
